{
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(make:*)",
      "Bash(./setup:*)",
      "Bash(./install:*)",
      "Bash(git:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Read(~/.gitconfig)",
      "Read(~/.bashrc)",
      "Read(~/.zshrc)",
      "Read(~/.vimrc)",
      "Read(~/.tmux.conf)",
      "Bash(gh:*)",
      "Bash(ghq:*)",
      "mcp__notion__notion-*",
      "mcp__github__*"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo rm:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code is waiting (permission/input)\" with title \"Claude\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
